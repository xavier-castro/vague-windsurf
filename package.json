{
  "name": "vague-windsurf",
  "displayName": "Vague Theme (Windsurf)",
  "description": "A cool, dark, low contrast colorscheme for Windsurf. Pastel yet vivid, like a fleeting memory...",
  "version": "1.0.2",
  "publisher": "xavier-castro",
  "author": {
    "name": "Xavier Castro",
    "url": "https://github.com/xavier-castro"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xavier-castro/vague-windsurf.git"
  },
  "bugs": {
    "url": "https://github.com/xavier-castro/vague-windsurf/issues"
  },
  "homepage": "https://github.com/xavier-castro/vague-windsurf",
  "engines": {
    "vscode": "^1.74.0"
  },
  "scripts": {
    "package:vsix": "npx @vscode/vsce package",
    "release:patch": "npm version patch --no-git-tag-version && npm run package:vsix"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "dark",
    "light",
    "vague",
    "low contrast",
    "pastel",
    "windsurf"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Vague",
        "uiTheme": "vs-dark",
        "path": "themes/vague-color-theme.json"
      },
      {
        "label": "Vague Light",
        "uiTheme": "vs",
        "path": "themes/vague-light-color-theme.json"
      }
    ]
  },
  "license": "MIT"
}
