        "string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#e8b589"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.type",
        "support.class",
        "support.orther.namespace.use.php",
        "meta.use.php",
